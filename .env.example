# computer-use-mcp configuration. Copy this file to .env and adjust as needed.
# All values have sensible defaults; you can leave .env empty for a normal setup.

# --- Screen / coordinate grounding ---
# Longest side (px) to downscale screenshots to before sending to Claude.
# ~1280 is the sweet spot for coordinate accuracy AND low image-token cost.
COMPUTER_USE_MAX_DIM=1280

# Default monitor to capture & control. 1 = primary, 2.. = other monitors,
# 0 = ALL screens at once (the whole virtual desktop). The agent can also pass
# `monitor=<index>` per call, and use action="monitors" to detect the setup.
COMPUTER_USE_MONITOR=1

# JPEG/PNG: PNG is lossless & crisp text (recommended). Set to "jpeg" to cut tokens further.
COMPUTER_USE_IMAGE_FORMAT=png

# --- Pacing / safety ---
# Seconds pyautogui pauses after every action. Higher = easier to interrupt & watch.
COMPUTER_USE_PAUSE=0.15

# Global panic hotkey that hard-kills the server (and thus all automation).
COMPUTER_USE_PANIC_HOTKEY=ctrl+alt+q

# Show the always-on-top STOP button + current-action overlay. 1=on, 0=off.
COMPUTER_USE_OVERLAY=1

# Mouse-move duration (seconds) so the cursor glides like a human instead of teleporting.
COMPUTER_USE_MOVE_DURATION=0.4

# Stand down (close overlay + release panic hotkey) after this many idle seconds.
# The agent can also stand down immediately with action="stop". 0 = never auto-stop.
COMPUTER_USE_IDLE_STOP=30
